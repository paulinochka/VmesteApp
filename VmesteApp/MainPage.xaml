<Page x:Class="VmesteApp.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="MainShellPage">

    <Border Background="#F5F5F7" CornerRadius="15" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="15,0,0,15" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,10,0,40">
                        <Ellipse Width="50" Height="50">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="/Images/avatar.jpg" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <StackPanel VerticalAlignment="Center" Margin="15,0,0,0">
                            <TextBlock Text="Полина" FontWeight="SemiBold" FontSize="16" Foreground="#333333"/>
                            <TextBlock Text="Глава семьи" FontSize="12" Foreground="#888888"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <Button Name="HomePageButton" Content="Главная" Click="HomePageButton_Click" Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,8"/>
                        <Button Name="CalendarButton" Content="Календарь" Click="CalendarButton_Click" Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,8"/>
                        <Button Name="ProfileButton" Content="Личный кабинет" Click="ProfileButton_Click" Style="{StaticResource MenuButtonStyle}" Margin="0,0,0,8"/>
                    </StackPanel>

                    <Button x:Name="LogoutButton" Grid.Row="2" Content="Выйти из аккаунта" Click="LogoutButton_Click" Style="{StaticResource ExitButtonStyle}" Margin="0,0,0,10"/>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,10,0">
                    <Button Content="—" Style="{StaticResource ControlButtonStyle}"/>
                    <Button Content="✕" Style="{StaticResource CloseButtonStyle}"/>
                </StackPanel>

                <TextBlock Grid.Row="0" Text="ВМЕСТЕ" HorizontalAlignment="Center" VerticalAlignment="Center" 
                           FontWeight="Bold" Foreground="#BDBDBD" />

                <Frame Grid.Row="1" Name="InnerFrame" NavigationUIVisibility="Hidden" Margin="10"/>
            </Grid>
        </Grid>
    </Border>
</Page>