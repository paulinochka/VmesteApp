<Page x:Class="VmesteApp.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная сводка">

    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30,0,30,30">
            <StackPanel MaxWidth="1000" HorizontalAlignment="Stretch">

                <TextBlock Text="Добрый день, Полина!" FontSize="28" FontWeight="Bold" 
                           Foreground="#333333" Margin="0,0,0,20"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="30" 
        BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,15,0" MinHeight="400">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,25">
                                <TextBlock Text="Задачи на сегодня" FontSize="20" FontWeight="Bold" Foreground="#333333"/>
                                <TextBlock Text="📝" HorizontalAlignment="Right" FontSize="20"/>
                            </Grid>

                            <StackPanel Grid.Row="1" VerticalAlignment="Top">
                                <CheckBox Content="Купить билеты до Дубая" Margin="0,0,0,15" FontSize="15" IsChecked="True"/>
                                <CheckBox Content="Забронировать отель в Таиланде" Margin="0,0,0,15" FontSize="15"/>
                                <CheckBox Content="Обменять валюту" Margin="0,0,0,15" FontSize="15"/>
                                <CheckBox Content="Проверить сроки паспортов" Margin="0,0,0,15" FontSize="15"/>
                            </StackPanel>

                            <Button Grid.Row="2" Content="+ Добавить задачу" 
                Margin="0,20,0,0" 
                Foreground="#7F8C8D" FontSize="14" FontWeight="Medium"
                HorizontalAlignment="Left" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="10,5"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" 
                                        Background="{TemplateBinding Background}" 
                                        CornerRadius="5" 
                                        Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#F2F2F2"/>
                                                            <Setter Property="Foreground" Value="#333333"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="30" 
                            BorderBrush="#E0E0E0" BorderThickness="1" Margin="15,0,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,25">
                                <TextBlock Text="Ближайшие события" FontSize="20" FontWeight="Bold" Foreground="#333333"/>
                                <TextBlock Text="📅" HorizontalAlignment="Right" FontSize="20"/>
                            </Grid>

                            <Border Background="#F9F9F9" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Перелет в Дубай" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                                        <TextBlock Text="29 июня, 14:20" FontSize="12" Foreground="#7F8C8D" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="✈️" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="18"/>
                                </Grid>
                            </Border>

                            <Border Background="#F9F9F9" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Прибытие в Дананг" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                                        <TextBlock Text="1 июля, 09:00" FontSize="12" Foreground="#7F8C8D" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="🏠" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="18"/>
                                </Grid>
                            </Border>

                            <Border Background="#F9F9F9" CornerRadius="10" Padding="15">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Встреча с программистами" FontWeight="SemiBold" FontSize="14" Foreground="#333"/>
                                        <TextBlock Text="5 июля, 19:00" FontSize="12" Foreground="#7F8C8D" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="💻" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="18"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>