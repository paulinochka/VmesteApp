<Page x:Class="VmesteApp.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Регистрация">
    <Border Background="#F5F5F7" CornerRadius="15" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid Background="Transparent">
            <StackPanel VerticalAlignment="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,10,0" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Name="MinimizeButton" Content="—" Style="{StaticResource MinimazeButtonStyle}" Click="MinimizeButton_Click"/>
                <Button Name="CloseButton" Content="✕" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click" />
            </StackPanel>

            <Border Background="White" CornerRadius="15" Margin="30" 
                VerticalAlignment="Center" HorizontalAlignment="Center" 
                Width="400" BorderBrush="#E0E0E0" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Hidden" Padding="30">
                    <StackPanel>
                        <TextBlock Text="Регистрация" FontSize="24" FontWeight="Bold" 
                               Foreground="#333" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                        <TextBlock Text="Имя" FontSize="12" Foreground="#999" Margin="5,0,0,5"/>
                        <TextBox x:Name="NameBox" Margin="0,0,0,12"/>

                        <TextBlock Text="Почта" FontSize="12" Foreground="#999" Margin="5,0,0,5"/>
                        <TextBox x:Name="EmailBox" Margin="0,0,0,12"/>

                        <TextBlock Text="Телефон" FontSize="12" Foreground="#999" Margin="5,0,0,5"/>
                        <TextBox x:Name="PhoneBox" Margin="0,0,0,12"/>

                        <TextBlock Text="Пароль" FontSize="12" Foreground="#999" Margin="5,0,0,5"/>
                        <PasswordBox x:Name="PassBox" Margin="0,0,0,12"/>

                        <TextBlock Text="Роль в семье" FontSize="12" Foreground="#999" Margin="5,0,0,5"/>
                        <ComboBox x:Name="RoleComboBox" 
                                  WindowChrome.IsHitTestVisibleInChrome="True" 
                                  Margin="0,0,0,20"
                                  SelectionChanged="RoleComboBox_SelectionChanged">
                            <ComboBoxItem Content="Глава семьи"/>
                            <ComboBoxItem Content="Участник семьи"/>
                        </ComboBox>

                        <StackPanel x:Name="FamilyCodeGroup" Visibility="Collapsed">
                            <TextBlock Text="Код семьи (если есть)" FontSize="12" Foreground="#999" Margin="5,-8,0,5"/>
                            <TextBox x:Name="FamilyCodeBox" Margin="0,0,0,20"/>
                        </StackPanel>

                        <Button Name="RegisterButton"
                            Content="Создать аккаунт" 
                            Style="{StaticResource MainButtonStyle}"
                            HorizontalAlignment="Center"
                            Width="300" 
                            Margin="0,0,0,15"
                            Click="RegisterButton_Click"/>

                        <TextBlock x:Name="ReturnButton"
                               Text="Назад ко входу" 
                               Foreground="{StaticResource AccentColor}" 
                               FontSize="12" FontWeight="Bold" 
                               Cursor="Hand" HorizontalAlignment="Center"
                               MouseLeftButtonDown="ReturnButton_MouseLeftButtonDown"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Page>