<Page x:Class="VmesteApp.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Авторизация">
    
    <Border Background="#F5F5F7" CornerRadius="15" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid Background="Transparent">
            <StackPanel VerticalAlignment="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,10,0" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Name="MinimizeButton" 
                    Content="—" 
                    Style="{StaticResource MinimazeButtonStyle}" 
                    Click="MinimizeButton_Click"/>
                <Button Name="CloseButton" 
                    Content="✕" 
                    Style="{StaticResource CloseButtonStyle}" 
                    Click="CloseButton_Click"/>
            </StackPanel>

            <Border Background="White" CornerRadius="15" Padding="40" 
                VerticalAlignment="Center" HorizontalAlignment="Center" 
                Width="350" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Вход в систему" FontSize="24" FontWeight="Bold" 
                           Foreground="#333" Margin="0,0,0,25" HorizontalAlignment="Center"/>

                    <TextBlock Text="Почта или номер телефона" FontSize="12" Foreground="#999" Margin="5,0,0,5"/>
                    <TextBox x:Name="LoginBox" Margin="0,0,0,15"/>

                    <TextBlock Text="Пароль" FontSize="12" Foreground="#999" Margin="5,0,0,5"/>
                    <PasswordBox x:Name="PassBox" Margin="0,0,0,25"/>

                    <Button Name="LoginButton"
                        Content="Войти" 
                        Style="{StaticResource MainButtonStyle}"
                        HorizontalAlignment="Center"
                        Width="270" 
                        Click="LoginButton_Click"
                        Margin="0,0,0,20"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Ещё нет аккаунта? " Foreground="#7F8C8D" FontSize="12"/>
                        <TextBlock x:Name="RegisterButton"
                               Text="Создать" 
                               Foreground="{StaticResource AccentColor}" 
                               FontSize="12"
                               FontWeight="Bold" 
                               Cursor="Hand"
                               MouseLeftButtonDown="RegisterButton_MouseLeftButtonDown"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Page>