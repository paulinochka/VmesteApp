<Window x:Class="VmesteApp.CustomMessageBoxYesNo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VmesteApp"
        mc:Ignorable="d"
                Title="Уведомление" Height="180" Width="350"
        WindowStyle="None" AllowsTransparency="True" 
        SizeToContent="WidthAndHeight"
        Background="Transparent" WindowStartupLocation="CenterScreen">

    <Border Background="White" CornerRadius="15" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Name="txtTitle" Text="Заголовок" FontWeight="Bold" FontSize="20" Foreground="#333"/>

            <TextBlock Name="txtMessage" Grid.Row="1" Text="Сообщение..." TextWrapping="Wrap" 
                       VerticalAlignment="Center" Margin="0,10" Foreground="#666" FontSize="16"/>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button  Content="Нет" Width="100" HorizontalAlignment="Right"
                        Style="{StaticResource MainButtonStyle}" Click="ButtonNo_Click" 
                        Margin="0,0,10,0"/>
                <Button Content="Да" Width="100" HorizontalAlignment="Right"
                        Style="{StaticResource MainButtonStyle}" Click="ButtonYes_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>