<Page x:Class="VmesteApp.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Личный кабинет">

    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="30,0,30,30">
            <StackPanel HorizontalAlignment="Stretch" MaxWidth="1000">

                <TextBlock Text="Личный кабинет" FontSize="28" FontWeight="Bold" 
                           Foreground="#333333" Margin="0,0,0,20"/>

                <Border Background="White" CornerRadius="15" Padding="40" 
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>

                        <Grid Margin="0,0,0,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Width="100" Height="100" Cursor="Hand" ToolTip="Нажмите, чтобы сменить фото">
                                <Border x:Name="AvatarBorder" CornerRadius="50" Padding="0" BorderBrush="#D0D0D0" BorderThickness="1">
                                    <Image x:Name="AvatarImage" 
                                           Source="/Avatars/nophoto.png" 
                                           Stretch="UniformToFill" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center">
                                        <Image.OpacityMask>
                                            <VisualBrush>
                                                <VisualBrush.Visual>
                                                    <Ellipse Width="100" Height="100" Fill="Black"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Image.OpacityMask>
                                    </Image>
                                </Border>

                                <Border x:Name="HoverOverlay" CornerRadius="50" Background="#99000000" IsHitTestVisible="False">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Opacity" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="📷" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" Margin="0,-10,0,0" Foreground="White"/>
                                </Border>
                                <Button Opacity="0" Click="ChangeAvatarClick"/>
                            </Grid>

                            <StackPanel Grid.Column="1" Margin="25,0,0,0" VerticalAlignment="Center">
                                <TextBox x:Name="UserNameTextBox" Text="Имя" 
                                         FontSize="22" FontWeight="SemiBold" 
                                         Foreground="#333333" Background="Transparent" 
                                         BorderThickness="0" Padding="5" Cursor="IBeam">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F2F2F2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <TextBlock x:Name="UserRoleTextBlock" 
                                           Text="Роль" FontSize="15" Foreground="#5D6D7E" 
                                           Margin="5,5,0,0" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>

                        <Separator Background="#EEEEEE" Height="1" Margin="0,10,0,30"/>

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,20,0">
                                <TextBlock Text="Электронная почта" FontSize="12" Foreground="#999" Margin="5,0,0,8"/>
                                <TextBox x:Name="UserEmailTextBox" Text="example@mail.com" Margin="0,0,0,25"/>

                                <TextBlock Text="Номер телефона" FontSize="12" Foreground="#999" Margin="5,0,0,8"/>
                                <TextBox x:Name="UserPhoneTextBox" 
                                         Text="+7 (999) 000-00-00" 
                                         Margin="0,0,0,25"
                                         GotFocus="UserPhoneTextBox_GotFocus"
                                         TextChanged="UserPhoneTextBox_TextChanged"/>
                            </StackPanel>

                            <StackPanel Margin="20,0,0,0">
                                <TextBlock Text="Код семьи" FontSize="12" Foreground="#999" Margin="5,0,0,8"/>
                                <TextBox x:Name="FamilyIdTextBox" Text="FAM-77A2-B9" IsReadOnly="True" IsEnabled="False" Margin="0,0,0,25"/>

                                <TextBlock Text="Новый пароль" FontSize="12" Foreground="#999" Margin="5,0,0,8"/>
                                <PasswordBox x:Name="NewPasswordBox" Password="newpassword" Margin="0,0,0,25"/>
                            </StackPanel>
                        </UniformGrid>

                        <Button x:Name="SaveButton"
                                Content="Сохранить изменения" 
                                Style="{StaticResource MainButtonStyle}"
                                HorizontalAlignment="Center" 
                                Margin="0,20,0,0"
                                Click="SaveButton_Click"/>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>